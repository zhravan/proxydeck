{
  "name": "proxydeck",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun run build:client",
    "build:client": "bun build src/client/entry.tsx --outdir=dist/assets --minify --sourcemap=external --target=browser",
    "db:migrate": "bun db/run-migrate.ts",
    "start": "bun src/index.ts"
  },
  "dependencies": {
    "better-auth": "^1.5.5",
    "elysia": "^1.1.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.0.0"
  }
}
